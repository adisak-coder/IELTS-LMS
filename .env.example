# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Development only: Vite dev-server proxy target for backend API requests.
VITE_BACKEND_API_URL="http://127.0.0.1:4000"

# Production testing: API base URL for Railway deployment
# Set automatically in CI/CD during Railway deployment
VITE_API_BASE_URL="https://your-railway-app.railway.app"

# Cache, RAM, and retention guardrails
# Use RESOURCE_PROFILE=low for tiny one-instance deployments around 1 CPU, 1 GiB RAM, and 5 GiB disk.
RESOURCE_PROFILE=""
# API-only low-memory tuning for glibc allocator (idle-RSS optimization)
API_MALLOC_ARENA_MAX="1"
API_MALLOC_TRIM_THRESHOLD="131072"
API_MALLOC_MMAP_THRESHOLD="131072"
# Keep API OTEL disabled unless intentionally configured
API_OTEL_EXPORTER_OTLP_ENDPOINT=""
RATE_LIMITER_BUCKET_CAP="10000"
RETENTION_CLEANUP_BATCH_LIMIT="1000"
RETENTION_SHARED_CACHE_GRACE_HOURS="24"
RETENTION_IDEMPOTENCY_USABLE_HOURS="72"
RETENTION_IDEMPOTENCY_GRACE_HOURS="24"
RETENTION_HEARTBEAT_DAYS="7"
RETENTION_MUTATION_DAYS="30"
RETENTION_USER_SESSION_DAYS="30"
