      "link": null,
      "locked": false,
      "text": "A) Sequence mismatch\nclient clears queue + watermark and re-fetches session\n(assumes server already accepted)",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A) Sequence mismatch\nclient clears queue + watermark and re-fetches session\n(assumes server already accepted)",
      "lineHeight": 1.25,
